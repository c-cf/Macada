# For local development (without Docker)
# When running with Docker Compose, these are set in docker-compose.yml
PORT=8080
DATABASE_URL=postgres://macada:macada@localhost:15432/macada?sslmode=disable
REDIS_URL=redis://localhost:16379
ANTHROPIC_API_KEY=sk-ant-xxxxx
LOG_LEVEL=debug

# Security — change these in production
JWT_SECRET=change-me-in-production
SANDBOX_SECRET=change-me-in-production

# Sandbox settings
RUNTIME_IMAGE=macada-runtime:latest
CONTROL_PLANE_URL=http://backend:8080
SANDBOX_MEMORY_MB=512
SANDBOX_CPUS=0.5

# Vault (optional — 64 hex chars = 32 bytes AES-256-GCM key)
# VAULT_ENCRYPTION_KEY=
