# Production environment — copy to .env.prod and fill in the values.
# Usage: docker compose -f docker-compose.prod.yml --env-file .env.prod up -d

# ---------------------------------------------------------------------------
# Domain (required)
# ---------------------------------------------------------------------------
# Your public domain. Caddy will serve:
#   https://DOMAIN          — frontend
#   https://api.DOMAIN      — backend API
DOMAIN=example.com

# Client-side API URL baked into the frontend image at build time.
# Must match the Caddy routing above.
NEXT_PUBLIC_API_URL=https://api.example.com

# ---------------------------------------------------------------------------
# Database (required)
# ---------------------------------------------------------------------------
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_USER=managed_agents
POSTGRES_DB=managed_agents

# ---------------------------------------------------------------------------
# Anthropic (required)
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...

# ---------------------------------------------------------------------------
# Optional overrides
# ---------------------------------------------------------------------------
# Log verbosity: debug | info | warn | error
LOG_LEVEL=info

# Pull specific image tags instead of :latest
# BACKEND_IMAGE=ghcr.io/cchu-code/macada/backend:abc1234
# RUNTIME_IMAGE=ghcr.io/cchu-code/macada/runtime:abc1234
