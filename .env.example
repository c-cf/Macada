# Required: Your Anthropic API key (for agent LLM calls)
ANTHROPIC_API_KEY=sk-ant-xxxxx

# Required: Admin secret for bootstrap endpoint (creates first workspace + API key)
ADMIN_SECRET=change-me-to-a-long-random-string

# Required: JWT secret for frontend authentication (user login tokens)
JWT_SECRET=change-me-to-another-long-random-string

# Optional: Port customization (avoid collision with local services)
# BACKEND_PORT=8080
# FRONTEND_PORT=3000
# EXTERNAL_DB_PORT=15432       # For GUI tools like DBeaver (localhost:15432)
# EXTERNAL_REDIS_PORT=16379    # For redis-cli debugging (localhost:16379)
